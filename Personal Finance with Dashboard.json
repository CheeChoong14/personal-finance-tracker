    {
      "parameters": {
        "jsCode": "const rows = $input.all();\n\nconst totals = {};\nlet grandTotal = 0;\n\nfor (const row of rows) {\n  const category = row.json[\"Category\"] || \"Other\";\n  const amount = parseFloat(row.json[\"Amount in RM\"]) || 0;\n  \n  totals[category] = (totals[category] || 0) + amount;\n  grandTotal += amount;\n}\n\nconst labels = Object.keys(totals);\nconst values = Object.values(totals).map(v => Math.round(v * 100) / 100);\n\n// Build QuickChart config\nconst chartConfig = {\n  type: \"doughnut\",\n  data: {\n    labels: labels,\n    datasets: [{\n      data: values,\n      backgroundColor: [\n        \"#FF6384\", \"#36A2EB\", \"#FFCE56\", \"#4BC0C0\",\n        \"#9966FF\", \"#FF9F40\", \"#C9CBCF\"\n      ]\n    }]\n  },\n  options: {\n    plugins: {\n      title: {\n        display: true,\n        text: \"Spending by Category (RM)\",\n        font: { size: 18 }\n      },\n      legend: { position: \"bottom\" }\n    }\n  }\n};\n\n// Build text summary for the caption\nconst breakdown = labels.map((label, i) => {\n  const pct = ((values[i] / grandTotal) * 100).toFixed(1);\n  return `${label}: RM ${values[i]} (${pct}%)`;\n}).join(\"\\n\");\n\n// Simple recommendations\nconst topCategory = labels[values.indexOf(Math.max(...values))];\nconst recommendations = [\n  `💡 Your biggest spend is *${topCategory}* — review if this aligns with your priorities.`,\n  grandTotal > 1000 ? \"⚠️ Total spending is above RM 1,000 — consider setting a monthly budget.\" : \"✅ Total spending looks manageable.\",\n];\n\nreturn [{\n  json: {\n    chartConfig: JSON.stringify(chartConfig),\n    grandTotal: grandTotal.toFixed(2),\n    breakdown,\n    recommendations: recommendations.join(\"\\n\")\n  }\n}];"
      },
